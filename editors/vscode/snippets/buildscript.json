{
  "Solution": {
    "prefix": ["solution", "[solution]"],
    "body": [
      "[solution]",
      "name = ${1:MySolution}",
      "configurations = ${2:Debug, Release}",
      "platforms = ${3:Win32, x64}",
      ""
    ],
    "description": "A new solution section with name, configurations, and platforms."
  },
  "Project (EXE)": {
    "prefix": ["project", "[project"],
    "body": [
      "[project:${1:MyProject}]",
      "type = exe",
      "sources = ${2:src/**/*.cpp}",
      "headers = ${3:include/**/*.h}",
      "includes = ${4:include}",
      "std = ${5|17,14,20,23|}",
      "subsystem = ${6|Console,Windows|}",
      ""
    ],
    "description": "A new executable project section."
  },
  "Project (LIB)": {
    "prefix": ["project-lib", "staticlib"],
    "body": [
      "[project:${1:MyLib}]",
      "type = lib",
      "sources = ${2:src/**/*.cpp}",
      "headers = ${3:include/**/*.h}",
      "includes = ${4:include}",
      "std = ${5|17,14,20,23|}",
      ""
    ],
    "description": "A new static library project section."
  },
  "Project (DLL)": {
    "prefix": ["project-dll", "dynamiclib"],
    "body": [
      "[project:${1:MyDLL}]",
      "type = dll",
      "sources = ${2:src/**/*.cpp}",
      "headers = ${3:include/**/*.h}",
      "includes = ${4:include}",
      "defines = ${1}_EXPORTS",
      "std = ${5|17,14,20,23|}",
      ""
    ],
    "description": "A new DLL/shared library project section."
  },
  "Config Section": {
    "prefix": ["config", "[config"],
    "body": [
      "[config:${1:Debug}|${2:Win32}]",
      "optimization = ${3|Disabled,MinSize,MaxSpeed,Full|}",
      "runtime_library = ${4|MultiThreadedDebug,MultiThreaded,MultiThreadedDLL,MultiThreadedDebugDLL|}",
      "debug_info = ${5|ProgramDatabase,EditAndContinue,None|}",
      ""
    ],
    "description": "A configuration section with common compiler settings."
  },
  "Config with Template": {
    "prefix": ["config-template"],
    "body": [
      "[config:${1:Profile}|${2:x64}] : Template:${3:Release}",
      "${0}",
      ""
    ],
    "description": "A configuration section that inherits from a template."
  },
  "PCH Setup": {
    "prefix": ["pch", "precompiled"],
    "body": [
      "pch = Use",
      "pch_header = ${1:src/pch.h}",
      "",
      "${2:src/pch.cpp}:pch = Create",
      "${2:src/pch.cpp}:pch_header = ${3:pch.h}",
      ""
    ],
    "description": "Precompiled header setup with Use and Create."
  },
  "Output Directories": {
    "prefix": ["outdir", "output-dirs"],
    "body": [
      "outdir[Debug|${1:Win32}] = ${2:bin/Debug/}",
      "outdir[Release|${1:Win32}] = ${3:bin/Release/}",
      "intdir[Debug|${1:Win32}] = ${4:obj/Debug/}",
      "intdir[Release|${1:Win32}] = ${5:obj/Release/}",
      ""
    ],
    "description": "Configuration-specific output and intermediate directories."
  },
  "If Windows": {
    "prefix": ["if-windows", "if(windows)"],
    "body": [
      "if(windows) {",
      "\t${0}",
      "}"
    ],
    "description": "Conditional block for Windows platform."
  },
  "If Linux": {
    "prefix": ["if-linux", "if(linux)"],
    "body": [
      "if(linux) {",
      "\t${0}",
      "}"
    ],
    "description": "Conditional block for Linux platform."
  },
  "target_link_libraries": {
    "prefix": ["target_link_libraries", "tll"],
    "body": [
      "target_link_libraries(",
      "\t${1:LibName} ${2|PUBLIC,PRIVATE,INTERFACE|}",
      ")",
      ""
    ],
    "description": "CMake-style dependency declaration with visibility."
  },
  "Whole Archive target_link_libraries": {
    "prefix": ["whole-archive", "tll-whole"],
    "body": [
      "target_link_libraries(",
      "\t${1:LibName} ${2|PRIVATE,PUBLIC,INTERFACE|} WHOLE_ARCHIVE ${3:StaticLib}",
      ")",
      ""
    ],
    "description": "Dependency declaration that whole-archives the next static library."
  },
  "find_package": {
    "prefix": ["find_package"],
    "body": [
      "find_package(${1|Vulkan,OpenGL,SDL2,SDL3,DirectX9,DirectX10,DirectX11,DirectX12|}, REQUIRED)",
      ""
    ],
    "description": "Find and configure an external package."
  },
  "File Section": {
    "prefix": ["file", "[file"],
    "body": [
      "[file:${1:src/file.cpp}]",
      "${2:defines} = ${3:VALUE}",
      ""
    ],
    "description": "Per-file settings section."
  },
  "Kernel Driver Project": {
    "prefix": ["project-sys", "driver"],
    "body": [
      "[project:${1:MyDriver}]",
      "type = sys",
      "sources = ${2:src/**/*.c}",
      "headers = ${3:include/**/*.h}",
      "subsystem = Native",
      "entry_point = ${4:DriverEntry}",
      "ignore_all_default_libraries = true",
      ""
    ],
    "description": "A kernel-mode driver project."
  },
  "NASM Support": {
    "prefix": ["nasm", "asm-nasm"],
    "body": [
      "nasm = ${1:asm/**/*.asm}",
      "nasm_format = ${2|win64,win32,elf64,elf32,bin,macho64|}",
      "nasm_flags = ${3:-w+all}",
      "nasm_includes = ${4:asm/include}",
      ""
    ],
    "description": "NASM source and assembler settings."
  },
  "Message Compiler": {
    "prefix": ["mc", "message-compiler"],
    "body": [
      "mc = ${1:src/messages.mc}",
      "mc_header_dir = ${2:obj/messages}",
      "mc_rc_dir = ${3:obj/messages}",
      "mc_flags = ${4:-u}",
      ""
    ],
    "description": "Windows Message Compiler source and output settings."
  },
  "MIDL": {
    "prefix": ["midl", "idl"],
    "body": [
      "idl = ${1:src/interface.idl}",
      "midl_output_dir = ${2:obj/midl}",
      "midl_header = ${3:interface.h}",
      "midl_type_library = ${4:interface.tlb}",
      "midl_flags = ${5:-Oicf -robust}",
      ""
    ],
    "description": "MIDL source and generated file settings."
  },
  "custom_build": {
    "prefix": ["custom_build", "custom-build"],
    "body": [
      "custom_build(${1:src/input.file},",
      "\tcommand = ${2:tool %(FullPath)},",
      "\toutputs = ${3:obj/output.file},",
      "\tdescription = ${4:Generating output}",
      ")",
      ""
    ],
    "description": "Attach a custom build command to a file."
  },
  "Module Definition": {
    "prefix": ["module_def", "def_file"],
    "body": [
      "module_def = ${1:exports.def}",
      ""
    ],
    "description": "DLL module definition file."
  },
  "Complete Buildscript": {
    "prefix": ["buildscript-full", "sighmake"],
    "body": [
      "[solution]",
      "name = ${1:MySolution}",
      "configurations = Debug, Release",
      "platforms = ${2:x64}",
      "",
      "[project:${3:MyProject}]",
      "type = ${4|exe,lib,dll,sys,sys_lib|}",
      "sources = ${5:src/**/*.cpp}",
      "headers = ${6:include/**/*.h}",
      "includes = ${7:include}",
      "defines = ${8:_CRT_SECURE_NO_WARNINGS}",
      "std = ${9|17,14,20,23|}",
      "",
      "warning_level = ${10|Level3,Level0,Level1,Level2,Level4|}",
      "multiprocessor = true",
      "exception_handling = Sync",
      "",
      "subsystem = ${11|Console,Windows|}",
      ""
    ],
    "description": "A complete buildscript template with solution and project."
  }
}
